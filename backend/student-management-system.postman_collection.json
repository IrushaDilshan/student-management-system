              "raw": "{\n  \"firstName\": \"John\",\n  \"lastName\": \"Doe\",\n  \"email\": \"john.doe@example.com\",\n  \"phone\": \"0771234567\",\n  \"user\": {\n    \"id\": {{studentUserId}}\n  }\n}"
