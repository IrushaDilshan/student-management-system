{
  "info": {
    "_postman_id": "c0f4d8d7-5d41-4f34-8f0c-3cf0c1f0a001",
    "name": "Student Management System API",
    "description": "Postman collection for the Spring Boot student management backend.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Student Signup",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/auth/student/signup",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "student",
                "signup"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"student.john\",\n  \"email\": \"student.john@example.com\",\n  \"password\": \"P@ssw0rd123\"\n}"
            },
            "description": "Registers a new student account with PENDING status."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Response contains user details', function () {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json).to.have.property('id');",
                  "  pm.expect(json.username).to.eql('student.john');",
                  "  pm.expect(json.email).to.eql('student.john@example.com');",
                  "  pm.expect(json.role).to.eql('STUDENT');",
                  "  pm.expect(json.status).to.eql('PENDING');",
                  "});",
                  "const json = pm.response.json();",
                  "pm.collectionVariables.set('studentUserId', json.id);"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Get Pending Students",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/auth/admin/pending-students",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "admin",
                "pending-students"
              ]
            },
            "description": "Returns all users currently waiting for approval."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Response is an array', function () {",
                  "  pm.expect(pm.response.json()).to.be.an('array');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Approve Student",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/auth/admin/approve-student/{{studentUserId}}?status=ACTIVE",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "admin",
                "approve-student",
                "{{studentUserId}}"
              ],
              "query": [
                {
                  "key": "status",
                  "value": "ACTIVE"
                }
              ]
            },
            "description": "Approves or rejects a pending student. Use ACTIVE or REJECTED."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Approval message is returned', function () {",
                  "  pm.expect(pm.response.text()).to.include('Student status updated to: ACTIVE');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    },
