{
  "info": {
    "name": "Student Management System API - Role Based",
    "description": "API collection organized by user roles (Public, Admin, Teacher, Student). Variables are used for different tokens.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080",
      "type": "string"
    },
    {
      "key": "adminToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "teacherToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "studentToken",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "1. Public (No Auth Required)",
      "item": [
        {
          "name": "Student Signup",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"student1\",\n  \"email\": \"student1@example.com\",\n  \"password\": \"password123\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/student/signup",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "student", "signup"]
            }
          }
        },
        {
          "name": "Login (Get Token)",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"admin_or_teacher_or_student_username\",\n  \"password\": \"password123\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "login"]
            }
          }
        }
      ]
    },
    {
      "name": "2. Admin (Requires adminToken)",
      "item": [
        {
          "name": "Approve/Reject Student",
          "request": {
            "method": "PUT",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/auth/admin/approve-student/1?status=ACTIVE",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "admin", "approve-student", "1"],
              "query": [
                {
                  "key": "status",
                  "value": "ACTIVE",
                  "description": "ACTIVE or REJECTED"
                }
              ]
            }
          }
        },
        {
          "name": "Get Pending Students",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/auth/admin/pending-students",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "admin", "pending-students"]
            }
          }
        },
        {
          "name": "Dashboard Stats",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/admin/dashboard/stats",
              "host": ["{{baseUrl}}"],
              "path": ["api", "admin", "dashboard", "stats"]
            }
          }
        },
        {
          "name": "Add Teacher (User + Profile)",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"teacher1\",\n  \"email\": \"teacher1@example.com\",\n  \"password\": \"password123\",\n  \"firstName\": \"Alan\",\n  \"lastName\": \"Turing\",\n  \"phone\": \"1234567890\",\n  \"department\": \"Computer Science\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/admin/teachers",
              "host": ["{{baseUrl}}"],
              "path": ["api", "admin", "teachers"]
            }
          }
        },
        {
          "name": "Get All Teachers",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/teachers",
              "host": ["{{baseUrl}}"],
              "path": ["api", "teachers"]
            }
          }
        },
        {
          "name": "Get Teacher by ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/teachers/1",
              "host": ["{{baseUrl}}"],
              "path": ["api", "teachers", "1"]
            }
          }
        },
        {
          "name": "Update Teacher Profile",
          "request": {
            "method": "PUT",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"Alan\",\n  \"lastName\": \"Turing updated\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/teachers/1",
              "host": ["{{baseUrl}}"],
              "path": ["api", "teachers", "1"]
            }
          }
        },
        {
          "name": "Delete Teacher",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/teachers/1",
              "host": ["{{baseUrl}}"],
              "path": ["api", "teachers", "1"]
            }
          }
        },
        {
          "name": "Create Course",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Mathematics 101\",\n  \"description\": \"Basic Mathematics Course\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/courses",
              "host": ["{{baseUrl}}"],
              "path": ["api", "courses"]
            }
          }
        },
        {
          "name": "Update Course",
          "request": {
            "method": "PUT",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Mathematics 101\",\n  \"description\": \"Updated Description\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/courses/1",
              "host": ["{{baseUrl}}"],
              "path": ["api", "courses", "1"]
            }
          }
        },
        {
          "name": "Assign Teacher to Course",
          "request": {
            "method": "PUT",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/courses/1/assign-teacher/1",
              "host": ["{{baseUrl}}"],
              "path": ["api", "courses", "1", "assign-teacher", "1"]
            }
          }
        },
        {
          "name": "Delete Course",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/courses/1",
              "host": ["{{baseUrl}}"],
              "path": ["api", "courses", "1"]
            }
          }
        }
      ],
      "auth": {
        "type": "bearer",
        "bearer": [
          {
            "key": "token",
            "value": "{{adminToken}}",
            "type": "string"
          }
        ]
      }
    },
