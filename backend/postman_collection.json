        },
        {
          "name": "Create Course",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Advanced Physics\",\n  \"description\": \"Physics for Seniors\"\n}",
              "options": {
