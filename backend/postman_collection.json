            "url": {
              "raw": "{{baseUrl}}/api/courses/1",
              "host": ["{{baseUrl}}"],
              "path": ["api", "courses", "1"]
            }
          }
        }
      ],
      "auth": {
        "type": "bearer",
        "bearer": [
          {
            "key": "token",
            "value": "{{teacherToken}}",
            "type": "string"
          }
        ]
      }
    },
